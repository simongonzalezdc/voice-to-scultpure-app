### 2.2 Audio Data Structures

```ts
// Shared Memory Buffer Layout
// [0]: Write Pointer
// [1]: Read Pointer
// [2...N]: Circular Audio Buffer (Float32)
export type AudioRingBuffer = {
  sharedBuffer: SharedArrayBuffer;
  writer: Float32Array; // Viewed in Worklet
  reader: Float32Array; // Viewed in Analysis Worker
};

export type AnalysisFrame = {
  time: number;
  pitch: number; // Hz
  confidence: number; // 0..1
  energy: number; // RMS
  timbre: number; // Spectral Centroid (Brightness)
  onsets: boolean;
};
